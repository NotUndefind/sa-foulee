# saFoulee Backend — Variables d'environnement
# Copier ce fichier en .env pour le développement

APP_NAME=saFoulee
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Base de données MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=safoulee
DB_USERNAME=root
DB_PASSWORD=

# Cache & Queue (database driver pour shared hosting)
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie

# Cloudflare R2 (stockage documents)
FILESYSTEM_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=safoulee-documents
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_URL=
R2_REGION=auto

# Pusher (chat temps réel)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
BROADCAST_CONNECTION=pusher

# Resend (emails transactionnels)
MAIL_MAILER=resend
RESEND_API_KEY=

MAIL_FROM_ADDRESS=noreply@safoulee.fr
MAIL_FROM_NAME="sa Foulée"

# Strava API (conditionnel)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=${APP_URL}/api/v1/strava/callback

# Cors (origines autorisées)
FRONTEND_URL=http://localhost:3000
