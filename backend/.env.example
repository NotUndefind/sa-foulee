# saFoulee Backend — Variables d'environnement
# Copier ce fichier en .env pour le développement local
# Pour la production O2switch, configurer directement le .env sur le serveur

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="La Neuville TAF sa Foulée"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Production : APP_URL=https://back.laneuvilletafsafoulee.fr

# ─── Base de données MySQL ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=safoulee
DB_USERNAME=root
DB_PASSWORD=
# Production : DB_DATABASE=bube0019_safoulee_prod
#              DB_USERNAME=bube0019_safoulee_prod
#              DB_PASSWORD=your_password

# ─── Cache & Queue (database driver pour shared hosting O2switch) ──────────────
CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=cookie
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── CORS (origines autorisées) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production : FRONTEND_URL=https://www.laneuvilletafsafoulee.fr

# ─── Emails transactionnels (SMTP O2switch en production) ─────────────────────
# Dev local — désactivé (log driver)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@laneuvilletafsafoulee.fr
MAIL_FROM_NAME="La Neuville TAF Sa Foulée"

# Production O2switch (SMTP) :
# MAIL_MAILER=smtp
# MAIL_HOST=vivaldi.o2switch.net
# MAIL_PORT=465
# MAIL_USERNAME=login@laneuvilletafsafoulee.fr
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=login@laneuvilletafsafoulee.fr
# MAIL_FROM_NAME="La Neuville TAF Sa Foulée"

# Alternative Resend (post-sprint) :
# MAIL_MAILER=resend
# RESEND_API_KEY=
# MAIL_FROM_ADDRESS=noreply@laneuvilletafsafoulee.fr

# Newsletter (STORY-V2-N04)
# NEWSLETTER_FROM_ADDRESS=newsletter@laneuvilletafsafoulee.fr

# ─── Cloudflare R2 (stockage documents membres — post-sprint) ─────────────────
# FILESYSTEM_DISK=r2
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=safoulee-documents
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_URL=
# R2_REGION=auto

# ─── HelloAsso (paiements cotisations — post-sprint) ──────────────────────────
# HELLOASSO_FORM_URL=https://www.helloasso.com/associations/safoulee/adhesions/adhesion
# HELLOASSO_WEBHOOK_SECRET=

# ─── Pusher (chat temps réel — post-sprint) ───────────────────────────────────
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=eu
# BROADCAST_CONNECTION=pusher

# ─── Strava API (post-sprint) ─────────────────────────────────────────────────
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=${APP_URL}/api/v1/strava/callback
